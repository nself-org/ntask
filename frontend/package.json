{
  "name": "nself-task",
  "version": "0.1.0",
  "description": "ɳTask - Universal Next.js reference app with multi-backend support (ɳSelf, Supabase, Nhost)",
  "author": "nself-org",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nself-org/tasks"
  },
  "keywords": [
    "ɳself",
    "ɳtasks",
    "tasks",
    "nextjs",
    "react",
    "hasura",
    "postgres",
    "supabase",
    "nhost",
    "boilerplate",
    "starter"
  ],
  "private": false,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest --config config/vitest.config.ts",
    "test:ui": "vitest --ui --config config/vitest.config.ts",
    "test:run": "vitest run --config config/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config config/vitest.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "db:seed": "tsx scripts/seed.ts",
    "prepare": "husky install",
    "postinstall": "husky install || true",
    "mobile:sync": "pnpm dlx cap sync",
    "mobile:android": "pnpm dlx cap open android",
    "mobile:ios": "pnpm dlx cap open ios",
    "mobile:build:android": "cd android && ./gradlew assembleRelease && cd ..",
    "mobile:build:ios": "cd ios && xcodebuild -workspace App.xcworkspace -scheme App -configuration Release archive",
    "tv:android": "pnpm mobile:android",
    "tv:build": "pnpm mobile:build:android",
    "desktop:dev": "pnpm tauri dev --config platforms/desktop/tauri/tauri.conf.json",
    "desktop:build": "pnpm tauri build --config platforms/desktop/tauri/tauri.conf.json",
    "release": "./scripts/release.sh",
    "release:all": "./scripts/release.sh",
    "release:web": "pnpm build && cd out && zip -r ../../.releases/web/nself-tasks-web-$(node -p \"require('../package.json').version\")-$(date +%Y%m%d).zip .",
    "release:mobile": "pnpm build && pnpm dlx cap sync && cd android && ./gradlew assembleRelease && cp app/build/outputs/apk/release/app-release.apk ../../.releases/android/nself-tasks-$(node -p \"require('../package.json').version\")-$(date +%Y%m%d).apk"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^10.0.0",
    "@capacitor/android": "^8.1.0",
    "@capacitor/camera": "^8.0.1",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.2",
    "@capacitor/share": "^8.0.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.0",
    "@netlify/plugin-nextjs": "^5.15.1",
    "@next/swc-wasm-nodejs": "13.5.1",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-aspect-ratio": "^1.1.0",
