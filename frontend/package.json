    "@types/node": "22.12.0",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "autoprefixer": "10.4.21",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.3.0",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.14",
    "graphql": "^16.12.0",
    "graphql-request": "^7.4.0",
    "idb-keyval": "^6.2.2",
    "input-otp": "^1.2.4",
    "lucide-react": "^0.446.0",
    "next": "15.5.14",
    "next-intl": "^4.8.3",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.3.0",
    "postcss": "8.4.49",
    "react": "18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.53.0",
    "react-resizable-panels": "^2.1.3",
    "recharts": "^2.12.7",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.7.3",
    "vaul": "^0.9.9",
    "workbox-cacheable-response": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dotenv": "^6.1.1",
    "@typescript-eslint/parser": "8.57.2",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "dotenv": "^17.2.4",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "flatted": ">=3.4.2",
      "tar": ">=7.5.13",
      "serialize-javascript": ">=7.0.5",
      "yaml": ">=2.8.3",
      "eslint>ajv": "6.14.0",
      "@commitlint/config-validator>ajv": "8.18.0",
      "minimatch>brace-expansion": "5.0.5",
      "filelist>minimatch": "5.1.8",
      "workbox-build>ajv": "8.18.0",
      "vite>rollup": "4.60.0",
      "tinyglobby>picomatch": "4.0.4",
      "vitest>picomatch": "4.0.4",
      "eslint>minimatch": "3.1.5",
      "eslint-plugin-import>minimatch": "3.1.5",
      "eslint-plugin-jsx-a11y>minimatch": "3.1.5",
      "eslint-plugin-react>minimatch": "3.1.5",
      "glob>minimatch": "10.2.4"
    }
  }
}
